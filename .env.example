# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Required: your MemoryPlugin bearer token
# Get one at https://www.memoryplugin.com
MEMORY_PLUGIN_TOKEN=your_token_here

# Optional overrides (uncomment to use)
# CALL_OF_CORE_POLL_INTERVAL=0.5
# CALL_OF_CORE_FIRE_DELAY=2.0
# CALL_OF_CORE_SOURCE=my-watcher
